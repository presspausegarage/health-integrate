{
  "name": "@health-integrate/core",
  "version": "0.0.0",
  "private": true,
  "description": "Pure TypeScript library: PS360 template parsing, DataValue parsing, normalization, smoke-testing. No UI, no Tauri dependencies.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./parsers/*": "./src/parsers/*.ts",
    "./serializers/*": "./src/serializers/*.ts",
    "./types/*": "./src/types/*.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "fast-check": "^3.23.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
