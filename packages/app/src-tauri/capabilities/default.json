{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for the main window. Scoped per-view later in Phase 11d.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:app:default",
    "core:event:default",
    "core:path:default",
    "shell:allow-open",
    "dialog:default",
    "clipboard-manager:default",
    "fs:default"
  ]
}
